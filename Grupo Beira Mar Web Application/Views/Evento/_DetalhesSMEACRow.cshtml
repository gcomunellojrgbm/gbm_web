@model Grupo_Beira_Mar_Web_Application.ViewModels.DetalhesSMEACViewModel
@{
    // Obtém o índice para garantir que os nomes dos campos HTML sejam únicos e mapeáveis para a lista no ViewModel
    var index = ViewData["Index"] as int? ?? 0;
}

<div class="detalhe-smeac-row mb-3 p-3 border rounded">
    <input type="hidden" asp-for="IdDetalhesSMEAC" name="DetalhesSMEAC[@index].IdDetalhesSMEAC" />
    <input type="hidden" asp-for="IdSMEAC" name="DetalhesSMEAC[@index].IdSMEAC" />

    <div class="form-group row mb-2">
        <label asp-for="DescricaoDetalhe" class="col-sm-2 col-form-label">Descrição Detalhe</label>
        <div class="col-sm-10">
            <textarea id="DetalhesSMEAC_@(index)_DescricaoDetalhe" class="form-control" rows="2" name="DetalhesSMEAC[@index].DescricaoDetalhe">@(Model.DescricaoDetalhe)</textarea>
        </div>
        
        <div class="col-sm-10 offset-sm-2">
            <select asp-items="ViewBag.DescricaoAtend" class="form-select" onchange="onDescricaoAtend_Change(this, $('#DetalhesSMEAC_@(index)_DescricaoDetalhe'))">
                <option value="">Selecione...</option>
            </select>
        </div>

    </div>
    <div class="form-group row mb-2">
        <label asp-for="IdVeiculoAtendimento" class="col-sm-2 col-form-label">Veículo Atendimento</label>
        <div class="col-sm-4">
            <select asp-for="IdVeiculoAtendimento" asp-items="ViewBag.Veiculos" class="form-select" name="DetalhesSMEAC[@index].IdVeiculoAtendimento">
                <option value="">Selecione...</option>
            </select>
        </div>
    
        <label asp-for="IdUsuarioCampo" class="col-sm-2 col-form-label">Vigilante Campo</label>
        <div class="col-sm-4">
            <select asp-for="IdUsuarioCampo" asp-items="ViewBag.Usuarios" class="form-select" name="DetalhesSMEAC[@index].IdUsuarioCampo">
                <option value="">Selecione...</option>
            </select>
        </div>
    </div>

    <div class="form-group row mb-2">
        <label asp-for="DataDetalheChegada" class="col-sm-2 col-form-label">Data Chegada</label>
        <div class="col-sm-4">
            <input asp-for="DataDetalheChegada" class="form-control" type="datetime-local" name="DetalhesSMEAC[@index].DataDetalheChegada" />
        </div>
    
        <label asp-for="DataDetalheSaida" class="col-sm-2 col-form-label">Data Saída</label>
        <div class="col-sm-4">
            <input asp-for="DataDetalheSaida" class="form-control" type="datetime-local" name="DetalhesSMEAC[@index].DataDetalheSaida" />
        </div>
    </div>

    @if (Model.PodeRemover) 
    {
        <div class="d-flex justify-content-end mt-2">
            <button type="button" class="btn btn-danger btn-sm remove-detalhe-smeac">Remover</button>
        </div>
    }

</div>

<script>
    // Adiciona o evento de clique para o botão "Remover"
    document.querySelectorAll('.remove-detalhe-smeac').forEach(button => {
        button.onclick = function() {
            this.closest('.detalhe-smeac-row').remove();
        };
    });

    // É crucial ter os dropdowns disponíveis na ViewBag ou ViewData quando a partial é renderizada via AJAX.
    // Garanta que `ViewBag.Usuarios` e `ViewBag.Veiculos` sejam populados na Action `AddDetalheSMEAC`
    // da `EventoController` antes de retornar a partial view.
</script>
